model Payout {
  id            String        @id @default(cuid())
  orgId         String
  amount        Float
  status        PayoutStatus  @default(PENDING)
  transferRef   String?
  bankAccount   String
  bankCode      String
  bankName      String
  createdAt     DateTime      @default(now())
  completedAt   DateTime?

  org           Organisation  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("payouts")
}