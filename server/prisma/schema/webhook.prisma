model WebhookEvent {
  id            String    @id @default(cuid())
  eventType     String
  accountRef    String?
  txRef         String?
  amount        Float?
  payload       Json
  processed     Boolean   @default(false)
  processedAt   DateTime?
  reconciliationStatus WebhookReconciliationStatus?
  createdAt     DateTime  @default(now())

  @@index([txRef])
  @@index([processed])

  @@map("webhook_events")
}